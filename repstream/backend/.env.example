# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://repstream_user:secret@localhost:5432/repstream_db
HUB_SCHEMA=hub_insight360
DS_SCHEMA=ds_hub_syndb

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Dev / Testing ─────────────────────────────────────────────────────────────
# Set to true to skip JWT auth and use a hardcoded REP001/TERR-001 identity.
# NEVER enable in production.
DEV_SKIP_AUTH=false

# Set to true to return stub AI text instead of calling OpenAI.
# Useful when testing without an OPENAI_API_KEY.
LLM_STUB_MODE=false

# ── Business Rules ────────────────────────────────────────────────────────────
RX_TREND_HIGH_THRESHOLD=15.0
RX_TREND_LOW_THRESHOLD=-10.0
WEEKLY_TARGET_RATIO=0.65
OBJECTION_HIGH_THRESHOLD=8
OBJECTION_MEDIUM_MIN=3
