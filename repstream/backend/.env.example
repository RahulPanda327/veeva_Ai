# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=replace-with-your-database-url-in-production
HUB_SCHEMA= replace with-your-hub-schema-in-production
DS_SCHEMA= replace-with-your-ds-schema-in-production

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=replace-with-your-redis-url-in-production
CELERY_BROKER_URL=redis://localhost:
CELERY_RESULT_BACKEND=redis://localhost

# ── Response Cache (app/utils/response_cache.py, no Redis) ───────────────────
# How long a GET endpoint's response is cached, in minutes. 1440 = 24 hours.
RESPONSE_CACHE_TTL_MINUTES=1440

# ── Cache Warm-Up Schedule (scripts/warm_cache.py) ─────────────────────────────
# Daily time (24h "HH:MM") the warm-up task runs at. After changing this, run
# `python scripts/schedule_warm_cache.py` to apply it to the Windows scheduled task.
WARM_CACHE_TIME=06:00

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=[""]

# ── Dev / Testing ─────────────────────────────────────────────────────────────
# Set to true to skip JWT auth and use a hardcoded REP001/TERR-001 identity.
# NEVER enable in production.
DEV_SKIP_AUTH=false

# Set to true to return stub AI text instead of calling OpenAI.
# Useful when testing without an OPENAI_API_KEY.
LLM_STUB_MODE=false

# ── Business Rules ────────────────────────────────────────────────────────────
RX_TREND_HIGH_THRESHOLD=15.0
RX_TREND_LOW_THRESHOLD=-10.0
WEEKLY_TARGET_RATIO=0.65
OBJECTION_HIGH_THRESHOLD=8
OBJECTION_MEDIUM_MIN=3
